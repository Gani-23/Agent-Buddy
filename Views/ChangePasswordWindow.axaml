<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AgentBuddy.ViewModels"
        x:Class="AgentBuddy.Views.ChangePasswordWindow"
        x:DataType="vm:ChangePasswordViewModel"
        mc:Ignorable="d"
        Width="560"
        Height="420"
        MinWidth="560"
        MinHeight="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Change Portal Password">

    <Border Classes="DialogBackdrop">
        <Border Classes="DialogSurface">
            <StackPanel Spacing="16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Classes="DialogDot"/>
                        <TextBlock Text="Security" Classes="Kicker"/>
                    </StackPanel>
                    <TextBlock Text="Change Portal Password" Classes="DialogTitle"/>
                </StackPanel>

                <Grid ColumnDefinitions="160,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="10">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Agent ID"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Text="{Binding AgentId}"
                             Watermark="Agent ID"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Current Password"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding CurrentPassword}"
                             PasswordChar="•"
                             Watermark="Current password"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="New Password"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding NewPassword}"
                             PasswordChar="•"
                             Watermark="New password"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Confirm Password"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Text="{Binding ConfirmPassword}"
                             PasswordChar="•"
                             Watermark="Re-enter new password"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Text="{Binding ValidationMessage}"
                               IsVisible="{Binding HasValidationMessage}"
                               Foreground="#C62828"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </Grid>

                <TextBlock Text="Password validity is 68 days. Update it before expiry."
                           FontSize="11"
                           Foreground="{DynamicResource AppTextSecondaryBrush}"/>

                <Border Classes="DialogDivider" Margin="0,2"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button Classes="Secondary"
                            Content="Cancel"
                            Click="Cancel_Click"
                            Padding="16,8"/>
                    <Button Classes="Primary"
                            Content="Change Password"
                            Click="Save_Click"
                            Padding="16,8"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</Window>
